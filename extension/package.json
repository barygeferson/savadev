{
  "name": "sdev-language",
  "displayName": "sdev Language",
  "description": "Official VS Code support for the sdev programming language — syntax highlighting, snippets, a built-in run command, and a 25-language source translator.",
  "version": "1.1.0",
  "publisher": "sdev-lang",
  "author": { "name": "sdev" },
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://s-dev.lovable.app",
  "repository": { "type": "git", "url": "https://s-dev.lovable.app" },
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Snippets", "Formatters"],
  "keywords": ["sdev", "interpreter", "language", "esoteric", "fantasy", "i18n", "translator", "multilingual"],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:sdev",
    "onCommand:sdev.run",
    "onCommand:sdev.runSelection",
    "onCommand:sdev.openPlayground",
    "onCommand:sdev.translateFile",
    "onCommand:sdev.translateSelection",
    "onCommand:sdev.detectLanguage",
    "onCommand:sdev.openDocs",
    "onCommand:sdev.openBook"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sdev",
        "aliases": ["sdev", "Sdev"],
        "extensions": [".sdev", ".sdv"],
        "configuration": "./language-configuration.json",
        "icon": { "light": "./icon.png", "dark": "./icon.png" }
      }
    ],
    "grammars": [
      {
        "language": "sdev",
        "scopeName": "source.sdev",
        "path": "./syntaxes/sdev.tmLanguage.json"
      }
    ],
    "snippets": [
      { "language": "sdev", "path": "./snippets/sdev.json" }
    ],
    "commands": [
      { "command": "sdev.run", "title": "sdev: Run File", "icon": "$(play)" },
      { "command": "sdev.runSelection", "title": "sdev: Run Selection" },
      { "command": "sdev.openPlayground", "title": "sdev: Open Online Playground" },
      { "command": "sdev.translateFile", "title": "sdev: Translate File to English sdev", "icon": "$(globe)" },
      { "command": "sdev.translateSelection", "title": "sdev: Translate Selection to English sdev" },
      { "command": "sdev.detectLanguage", "title": "sdev: Detect Source Language" },
      { "command": "sdev.openDocs", "title": "sdev: Open Language Documentation" },
      { "command": "sdev.openBook", "title": "sdev: Open the sdev Book" }
    ],
    "menus": {
      "editor/title/run": [
        { "command": "sdev.run", "when": "resourceLangId == sdev", "group": "navigation@1" },
        { "command": "sdev.translateFile", "when": "resourceLangId == sdev", "group": "navigation@2" }
      ],
      "editor/context": [
        { "command": "sdev.runSelection", "when": "resourceLangId == sdev && editorHasSelection", "group": "z_sdev@1" },
        { "command": "sdev.translateSelection", "when": "resourceLangId == sdev && editorHasSelection", "group": "z_sdev@2" }
      ],
      "commandPalette": [
        { "command": "sdev.run", "when": "resourceLangId == sdev" },
        { "command": "sdev.runSelection", "when": "resourceLangId == sdev && editorHasSelection" },
        { "command": "sdev.translateFile", "when": "resourceLangId == sdev" },
        { "command": "sdev.translateSelection", "when": "resourceLangId == sdev && editorHasSelection" },
        { "command": "sdev.detectLanguage", "when": "resourceLangId == sdev" }
      ]
    },
    "keybindings": [
      { "command": "sdev.run", "key": "ctrl+enter", "mac": "cmd+enter", "when": "resourceLangId == sdev && editorTextFocus" },
      { "command": "sdev.runSelection", "key": "ctrl+shift+enter", "mac": "cmd+shift+enter", "when": "resourceLangId == sdev && editorHasSelection" },
      { "command": "sdev.translateFile", "key": "ctrl+alt+t", "mac": "cmd+alt+t", "when": "resourceLangId == sdev && editorTextFocus" }
    ],
    "configuration": {
      "title": "sdev",
      "properties": {
        "sdev.runner": {
          "type": "string",
          "enum": ["bundled", "node", "python"],
          "default": "bundled",
          "description": "Which runtime to use when running .sdev files. 'bundled' uses the interpreter shipped with this extension (no install required)."
        },
        "sdev.nodePath": {
          "type": "string",
          "default": "node",
          "description": "Path to the Node.js executable (used by 'bundled' and 'node' runners)."
        },
        "sdev.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python executable (used by the 'python' runner)."
        },
        "sdev.sourceLanguage": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto", "English", "Spanish", "French", "German", "Portuguese", "Italian",
            "Dutch", "Russian", "Chinese", "Japanese", "Korean", "Arabic", "Hindi",
            "Turkish", "Polish", "Swedish", "Norwegian", "Danish", "Finnish", "Greek",
            "Hebrew", "Ukrainian", "Czech", "Romanian", "Hungarian", "Bulgarian"
          ],
          "description": "Source language for the built-in translator. 'auto' detects the language automatically. 'English' disables translation."
        },
        "sdev.translate": {
          "type": "boolean",
          "default": true,
          "description": "Enable the built-in multi-language translator. When off, source is fed directly to the interpreter."
        },
        "sdev.showDetectedLanguage": {
          "type": "boolean",
          "default": true,
          "description": "After a run, show which human language the translator detected in the output channel."
        }
      }
    }
  }
}
